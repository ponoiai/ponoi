{
  "name": "ponoi",
  "private": true,
  "version": "1.251.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "gen-changelog": "node scripts/gen-changelog.mjs",
    "dev": "node scripts/gen-changelog.mjs && vite",
    "build": "node scripts/gen-changelog.mjs && vite build",
    "typecheck": "tsc",
    "preview": "vite preview",
    "electron:start": "electron .",
    "dist": "node scripts/gen-changelog.mjs && vite build && electron-builder --win",
    "cap:sync": "npm run build && cap sync android",
    "android:assets": "capacitor-assets generate --android --iconBackgroundColor #23272a --iconBackgroundColorDark #1e1f22 --splashBackgroundColor #23272a --splashBackgroundColorDark #1e1f22"
  },
  "dependencies": {
    "@capacitor/android": "8.4.1",
    "@capacitor/core": "8.4.1",
    "@livekit/krisp-noise-filter": "^0.4.3",
    "@supabase/supabase-js": "^2.45.0",
    "electron-updater": "^6.3.9",
    "livekit-client": "^2.18.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "8.4.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.ponoi.app",
    "productName": "Ponoi",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.ico"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "ponoiai",
      "repo": "ponoi",
      "releaseType": "release"
    },
    "artifactName": "Ponoi-Setup-${version}.${ext}",
    "nsis": {
      "include": "build/installer.nsh",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "shortcutName": "Ponoi",
      "uninstallDisplayName": "Ponoi"
    }
  }
}
