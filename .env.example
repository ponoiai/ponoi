VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# LiveKit (звонки) — URL берётся с сервера через edge function, тут ничего не нужно на клиенте

# Web Push (пуш-уведомления, когда приложение закрыто) — публичная половина VAPID-ключа
# (сгенерировать: npx web-push generate-vapid-keys). Приватную половину положи ТОЛЬКО
# секретом в Supabase (VAPID_PRIVATE_KEY) — см. supabase/functions/README.md.
VITE_VAPID_PUBLIC_KEY=
